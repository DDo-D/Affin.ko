#!/bin/zsh
# Install Korean strings directly into Affinity.app (same as affin-ko-apply --build)
set -euo pipefail

REPO_ROOT="${0:A:h}"
# shellcheck source=affin-ko-lib.zsh
source "${REPO_ROOT}/affin-ko-lib.zsh"

DICTIONARY="${REPO_ROOT}/.affin.ko.dictionary"
AFFINITY_APP="${AFFINITY_APP:-/Applications/Affinity.app}"

[[ -f "${DICTIONARY}" ]] || { echo "Dictionary missing: ${DICTIONARY}" >&2; exit 1 }

affin_ko_detect_app "${AFFINITY_APP}" >/dev/null || exit 1
affin_ko_version_check "${AFFINITY_APP}" || true

if [[ -z "${AFFIN_KO_NO_PULL:-}" ]]; then
  echo "→ Check update (git pull)"
  (cd "${REPO_ROOT}" && git pull) || true
fi

echo "→ Quitting Affinity"
pkill -f "Affinity" 2>/dev/null || true
sleep 1

echo "→ Building ko.lproj in place (UTF-16LE)"
affin_ko_build_from_app "${AFFINITY_APP}" "${TMPDIR:-/tmp}/affin-ko-install.$$" "${DICTIONARY}"
affin_ko_install_to_app "${TMPDIR:-/tmp}/affin-ko-install.$$" "${AFFINITY_APP}"
rm -rf "${TMPDIR:-/tmp}/affin-ko-install.$$"

open -a "${AFFINITY_APP}"
echo "→ Settings → General → Language → 한국어"
